@page "/clientes"

@using Microsoft.EntityFrameworkCore
@using ZapateriaApp.Data
@using ZapateriaApp.Models

@inject AppDbContext Context

<PageTitle>Clientes</PageTitle>

<h1>Gestión de Clientes</h1>

<hr />

<EditForm Model="nuevoCliente" OnValidSubmit="GuardarCliente">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="formulario">
        <input @bind="nuevoCliente.Nombre" placeholder="Nombre" />

        <input @bind="nuevoCliente.Telefono" placeholder="Teléfono" />

        <input @bind="nuevoCliente.Email" placeholder="Email" />

        <button type="submit">
            @(modoEdicion ? "Actualizar" : "Guardar")
        </button>

        @if (modoEdicion)
        {
            <button type="button" @onclick="CancelarEdicion">
                Cancelar
            </button>
        }
    </div>
</EditForm>

<hr />

@if (clientes == null)
{
    <p>Cargando clientes...</p>
}
else
{
    <table class="tabla-clientes">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th>Fecha Registro</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var cliente in clientes)
            {
                <tr>
                    <td>@cliente.Nombre</td>
                    <td>@cliente.Telefono</td>
                    <td>@cliente.Email</td>
                    <td>@cliente.FechaRegistro.ToShortDateString()</td>

                    <td>
                        <button @onclick="() => EditarCliente(cliente)">
                            Editar
                        </button>

                        <button @onclick="() => EliminarCliente(cliente.Id)">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {

    private List<Cliente>? clientes;

    private Cliente nuevoCliente = new();

    private bool modoEdicion = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        clientes = await Context.Clientes.ToListAsync();
    }

    private async Task GuardarCliente()
    {
        if (modoEdicion)
        {
            var clienteDb = await Context.Clientes.FindAsync(nuevoCliente.Id);

            if (clienteDb != null)
            {
                clienteDb.Nombre = nuevoCliente.Nombre;
                clienteDb.Telefono = nuevoCliente.Telefono;
                clienteDb.Email = nuevoCliente.Email;

                await Context.SaveChangesAsync();
            }
        }
        else
        {
            nuevoCliente.FechaRegistro = DateTime.Now;

            await Context.Clientes.AddAsync(nuevoCliente);

            await Context.SaveChangesAsync();
        }

        nuevoCliente = new Cliente();

        modoEdicion = false;

        await CargarClientes();
    }

    private void EditarCliente(Cliente cliente)
    {
        nuevoCliente = new Cliente
        {
            Id = cliente.Id,
            Nombre = cliente.Nombre,
            Telefono = cliente.Telefono,
            Email = cliente.Email,
            FechaRegistro = cliente.FechaRegistro
        };

        modoEdicion = true;
    }

    private async Task EliminarCliente(int id)
    {
        var cliente = await Context.Clientes.FindAsync(id);

        if (cliente != null)
        {
            Context.Clientes.Remove(cliente);

            await Context.SaveChangesAsync();

            await CargarClientes();
        }
    }

    private void CancelarEdicion()
    {
        nuevoCliente = new Cliente();

        modoEdicion = false;
    }
}