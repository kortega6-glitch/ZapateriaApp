@page "/ventas"

@using Microsoft.EntityFrameworkCore
@using ZapateriaApp.Data
@using ZapateriaApp.Models
@using ZapateriaApp.Services

@inject AppDbContext Context
@inject ApiService ApiService

<PageTitle>Ventas</PageTitle>

<h1>Registro de Ventas</h1>

<hr />

@if (clientes == null || productos == null)
{
    <p>Cargando información...</p>
}
else
{
    <div class="formulario-ventas">

        <div>
            <label>Cliente</label>

            <select @bind="clienteIdSeleccionado">
                <option value="0">Seleccione cliente</option>

                @foreach (var cliente in clientes)
                {
                    <option value="@cliente.Id">
                        @cliente.Nombre
                    </option>
                }
            </select>
        </div>

        <div>
            <label>Producto</label>

            <select @bind="productoIdSeleccionado">
                <option value="0">Seleccione producto</option>

                @foreach (var producto in productos)
                {
                    <option value="@producto.Id">
                        @producto.Nombre - $@producto.Precio
                    </option>
                }
            </select>
        </div>

        <div>
            <label>Cantidad</label>

            <input type="number" @bind="cantidad" />
        </div>

        <button @onclick="RegistrarVenta">
            Registrar Venta
        </button>

    </div>

    <hr />

    <h2>Historial de Ventas</h2>

    <table class="tabla-clientes">
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Fecha</th>
                <th>Total</th>
                <th>Estado</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var venta in ventas)
            {
                <tr>
                    <td>@venta.Cliente?.Nombre</td>

                    <td>@venta.Fecha.ToShortDateString()</td>

                    <td>$@venta.Total</td>

                    <td>@venta.Estado</td>
                </tr>
            }

        </tbody>
    </table>
}

@code {

    private List<Cliente>? clientes;

    private List<ProductoApi>? productos;

    private List<Venta> ventas = new();

    private int clienteIdSeleccionado;

    private int productoIdSeleccionado;

    private int cantidad = 1;

    protected override async Task OnInitializedAsync()
    {
        clientes = await Context.Clientes.ToListAsync();

        productos = await ApiService.ObtenerProductos();

        ventas = await Context.Ventas
            .Include(v => v.Cliente)
            .ToListAsync();
    }

    private async Task RegistrarVenta()
    {
        if (clienteIdSeleccionado == 0 ||
            productoIdSeleccionado == 0)
        {
            return;
        }

        var producto = productos?
            .FirstOrDefault(p => p.Id == productoIdSeleccionado);

        if (producto == null)
        {
            return;
        }

        decimal total = producto.Precio * cantidad;

        var venta = new Venta
        {
            ClienteId = clienteIdSeleccionado,
            Fecha = DateTime.Now,
            Total = total,
            Estado = "Completada"
        };

        await Context.Ventas.AddAsync(venta);

        await Context.SaveChangesAsync();

        var detalle = new DetalleVenta
        {
            VentaId = venta.Id,
            ProductoApiId = producto.Id,
            Cantidad = cantidad,
            Precio = producto.Precio
        };

        await Context.DetalleVentas.AddAsync(detalle);

        await Context.SaveChangesAsync();

        ventas = await Context.Ventas
            .Include(v => v.Cliente)
            .ToListAsync();

        clienteIdSeleccionado = 0;
        productoIdSeleccionado = 0;
        cantidad = 1;
    }
}